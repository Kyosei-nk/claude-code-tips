---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<BaseLayout
  title="Claude Code Tips JP"
  description="Claude Codeの使い方・Tips・設定方法を日本語で解説。初心者から上級者まで役立つ実践的な技術記事を公開中。"
>
  <section style="margin-bottom: 3rem; padding: 2rem 0;">
    <h1 style="font-size: 1.75rem; font-weight: 800; line-height: 1.4; margin-bottom: 1rem;">
      Claude Code Tips JP
    </h1>
    <p style="color: var(--text-muted); font-size: 1rem; line-height: 1.8; max-width: 560px;">
      Anthropic の AI コーディングツール <strong style="color: var(--text);">Claude Code</strong> の
      使い方・Tips・設定方法を日本語で発信しています。
      公式ドキュメントや実際の使用経験をもとに、実践的な情報をお届けします。
    </p>
  </section>

  {sortedPosts.length === 0 ? (
    <p style="color: var(--text-muted); text-align: center; padding: 3rem 0;">記事を準備中です。しばらくお待ちください。</p>
  ) : (
    <section>
      <h2 style="font-size: 1rem; font-weight: 700; margin-bottom: 1.25rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; border: none; padding: 0;">最新記事</h2>
      <div style="display: flex; flex-direction: column; gap: 1rem;">
        {sortedPosts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
