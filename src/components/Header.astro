---
const base = import.meta.env.BASE_URL;
---
<header style="border-bottom: 1px solid var(--border); background: var(--bg);">
  <nav style="max-width: 680px; margin: 0 auto; padding: 0 1rem; display: flex; align-items: center; justify-content: space-between; height: 56px;">
    <a href={base} style="font-weight: 700; font-size: 1rem; color: var(--text); text-decoration: none; display: flex; align-items: center; gap: 0.5rem;">
      <span style="color: var(--accent);">◆</span>
      Claude Code Tips JP
    </a>
    <div style="display: flex; gap: 1.25rem; font-size: 0.875rem;">
      <a href={`${base}/`} style="color: var(--text-muted);">記事一覧</a>
      <a href={`${base}/about`} style="color: var(--text-muted);">このサイトについて</a>
    </div>
  </nav>
</header>
